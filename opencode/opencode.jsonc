{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "mcp": {
    // "home-assistant": {
    //   "enabled": true,
    //   "type": "remote",
    //   "url": "{env:HOMEASSISTANT_URL}",
    //   "headers": {
    //     "Authorization": "Bearer {env:HOMEASSISTANT_TOKEN}"
    //   }
    // },
    "jira": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "notes/**": "deny"
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "cat*": "allow",
      "curl*": "deny",
      "echo*": "allow",
      "gh pr diff*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh search prs*": "allow",
      "git -C*": "deny",
      "git add*": "allow",
      "git branch*": "allow",
      "git commit*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git ls-files*": "allow",
      //"git push*": "allow",
      "git remote*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git switch*": "allow",
      "grep": "allow",
      "head": "allow",
      "ls*": "allow",
      "npx skills*": "allow",
      "pwd*": "allow",
      "ssh*": "deny",
      "sudo*": "deny",
      "tail": "allow",
      "true*": "allow",
      "wc*": "allow",
      "wget*": "deny",
      "which*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "mcp_jira": "allow"
  },
  "plugin": [
    // "@devtheops/opencode-plugin-otel",
    "opencode-mem",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ollama local",
      "options": {
        "baseURL": "https://olla.techtales.io/olla/ollama/v1"
      },
      "models": {
        "Agen/gemma-4-26B-A4B-it-uncensored-heretic:latest": {
          "name": "gemma4"
        }
      }
    }
  }
}
