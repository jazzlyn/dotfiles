{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  // "mcp": {
  //   "home-assistant": {
  //     "enabled": true,
  //     "type": "remote",
  //     "url": "https://hass.techtales.io/api/mcp",
  //     "oauth": {
  //       "clientId": "http://localhost:19876",
  //       "redirectUri": "http://localhost:19876/mcp/oauth/callback"
  //     }
  //   },
  //   "atlassian": {
  //     "enabled": true,
  //     "type": "remote",
  //     "url": "https://mcp.atlassian.com/v1/mcp"
  //   },
  //   "github": {
  //     "enabled": true,
  //     "type": "remote",
  //     "url": "https://api.githubcopilot.com/mcp",
  //     "oauth": false,
  //     "headers": {
  //       "Authorization": "Bearer {file:~/.secrets/github-token}"
  //     }
  //   }
  // },
  "permission": {
    "read": {
      "*": "allow",
      "*secret*": "ask",
      "~/.config/gh/**": "ask"
    },
    "edit": {
      "*": "allow",
      "*secret*": "ask"
    },
    "bash": {
      "*": "allow",
      "*secret*": "ask",
      "curl *-T*": "ask",
      "git push *": "ask",
      "~/.config/gh/**": "ask"
    },
    "external_directory": {
      "/home/opencode/**": "allow",
      "/srv/shared/**": "allow"
    },
    "doom_loop": "ask",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "mcp_atlassian": {
      "*": "ask",
      "atlassianUserInfo": "allow",
      "fetch": "allow",
      "get*": "allow",
      "lookup*": "allow",
      "search*": "allow"
    },
    "mcp_github": {
      "*": "ask",
      "get*": "allow",
      "issue_read": "allow",
      "list*": "allow",
      "pull_request_read": "allow",
      "search*": "allow"
    }
  },
  "plugin": [
    // "@devtheops/opencode-plugin-otel",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
