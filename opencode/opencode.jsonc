{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "mcp": {
    "home-assistant": {
      "enabled": true,
      "type": "remote",
      "url": "https://hass.techtales.io/api/mcp",
      "oauth": {
        "clientId": "http://localhost:19876",
        "redirectUri": "http://localhost:19876/mcp/oauth/callback"
      }
    },
    "atlassian": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "notes/**": "deny"
    },
    "edit": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "curl *": "deny",
      "echo *": "allow",
      "find *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh search prs *": "allow",
      "git -C *": "deny",
      "git add *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git push *": "ask",
      "git reflog *": "allow",
      "git remote *": "allow",
      "git show *": "allow",
      "git stash *": "allow",
      "git status *": "allow",
      "git switch *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "kustomize *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "npx skills *": "allow",
      "pwd *": "allow",
      "sort *": "allow",
      "ssh *": "deny",
      "sudo *": "deny",
      "tail *": "allow",
      "true *": "allow",
      "wc *": "allow",
      "wget *": "deny",
      "which *": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "/home/*/.agents/**": "allow",
      "/home/*/.cache/opencode/packages/**": "allow",
      "/home/*/dotfiles/**": "allow"
    },
    "mcp_atlassian": {
      "*": "ask",
      "atlassianUserInfo": "allow",
      "fetch": "allow",
      "get*": "allow",
      "lookup*": "allow",
      "search*": "allow"
    }
  },
  "plugin": [
    // "@devtheops/opencode-plugin-otel",
    "opencode-mem",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local",
      "options": {
        "baseURL": "https://olla.techtales.io/olla/ollama/v1"
      },
      "models": {
        "hermes3": {
          "id": "hermes3:8b",
          "name": "hermes3:8b",
          "tool_call": true,
          "options": {
            "temperature": 0.7
          }
        }
      }
    }
  }
}
