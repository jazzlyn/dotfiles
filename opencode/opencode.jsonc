{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "disabled_providers": ["github-models", "opencode"],
  "provider": {
    "github-copilot": {
      "whitelist": ["claude-sonnet-5", "claude-haiku-4.5"]
    },
    "opencode-go": {
      "whitelist": ["deepseek-v4-pro", "qwen3.7-plus"]
    }
  },
  "mcp": {
    "atlassian": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "home-assistant": {
      "enabled": true,
      "type": "remote",
      "url": "https://hass.techtales.io/api/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.secrets/hass-token}"
      }
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "external-secret.yaml": "allow",
      "secret.yaml": "allow",
      "*secret*": "ask",
      "~/.config/gh/**": "ask"
    },
    "edit": {
      "*": "allow",
      "external-secret.yaml": "allow",
      "secret.yaml": "allow",
      "*secret*": "ask"
    },
    "bash": {
      "*": "allow",
      "external-secret.yaml": "allow",
      "secret.yaml": "allow",
      "*secret*": "ask",
      "curl *-T*": "ask",
      "git push*": "ask",
      "gh pr create*": "ask",
      "gh pr merge*": "ask",
      "~/.config/gh/**": "ask"
    },
    "external_directory": {
      "/home/opencode/**": "allow",
      "/srv/shared/**": "allow"
    },
    "doom_loop": "ask",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "atlassian_*": "ask",
    "atlassian_atlassianUserInfo": "allow",
    "atlassian_fetch": "allow",
    "atlassian_get*": "allow",
    "atlassian_lookup*": "allow",
    "atlassian_search*": "allow",
    "github_*": "ask",
    "github_get*": "allow",
    "github_issue_read": "allow",
    "github_list*": "allow",
    "github_pull_request_read": "allow",
    "github_search*": "allow"
  },
  "plugin": [
    // "@devtheops/opencode-plugin-otel"
  ]
}
