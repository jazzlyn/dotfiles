{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoUpdaterStatus": "disabled",
  "editorMode": "vim",
  "effortLevel": "medium",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh search prs *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git switch *)",
      "Bash(grep *)",
      "Bash(head)",
      "Bash(ls *)",
      "Bash(npx skills *)",
      "Bash(pwd *)",
      "Bash(tail)",
      "Bash(true *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Glob",
      "Grep",
      "LSP",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "mcp__jira",
      "mcp__jira__*"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(git -C *)",
      "Bash(git push *)",
      "Bash(ssh *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/notes/**)"
    ]
  },
  "enabledPlugins": {
    "superpowers@git+https://github.com/obra/superpowers.git": true
  },
  "prefersReducedMotion": true,
  "theme": "auto",
  "tui": "fullscreen"
}
