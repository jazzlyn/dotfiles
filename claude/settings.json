{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(/home/*/projects/**)",
      "Read(/home/*/.claude/**)",
      "Edit(/home/*/projects/**)",
      "Edit(/home/*/.claude/**)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh search prs *)",
      "Bash(git -C /home/*/projects/** *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git switch *)",
      "Bash(find /home/*/projects/**)",
      "Bash(find /home/*/.claude/**)",
      "Bash(ls /home/*/projects/**)",
      "Bash(ls /home/*/.claude/**)",
      "Bash(pre-commit *)",
      "Bash(task *)",
      "Bash(which *)",
      "Glob",
      "Grep",
      "LSP",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "mcp__atlassian__atlassianUserInfo",
      "mcp__atlassian__fetch",
      "mcp__atlassian__getAccessibleAtlassianResources",
      "mcp__atlassian__getConfluenceCommentChildren",
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__getConfluencePageDescendants",
      "mcp__atlassian__getConfluencePageFooterComments",
      "mcp__atlassian__getConfluencePageInlineComments",
      "mcp__atlassian__getConfluenceSpaces",
      "mcp__atlassian__getIssueLinkTypes",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getJiraIssueRemoteIssueLinks",
      "mcp__atlassian__getJiraIssueTypeMetaWithFields",
      "mcp__atlassian__getJiraProjectIssueTypesMetadata",
      "mcp__atlassian__getPagesInConfluenceSpace",
      "mcp__atlassian__getTransitionsForJiraIssue",
      "mcp__atlassian__getVisibleJiraProjects",
      "mcp__atlassian__lookupJiraAccountId",
      "mcp__atlassian__search",
      "mcp__atlassian__searchConfluenceUsingCql",
      "mcp__atlassian__searchJiraIssuesUsingJql"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(git push *)",
      "Bash(ssh *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/.secrets/**)",
      "Read(**/notes/**)"
    ]
  },
  "enabledPlugins": {
    "gitops-skills@fluxcd": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "fluxcd": {
      "source": {
        "source": "github",
        "repo": "fluxcd/agent-skills"
      }
    }
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "prefersReducedMotion": true,
  "autoMemoryEnabled": true,
  "theme": "auto",
  "editorMode": "vim",
  "autoUpdaterStatus": "disabled"
}
